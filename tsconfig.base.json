{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2020"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,

    "baseUrl": ".",
    "paths": {
      "@ragemp-fivem-bridge/shared": ["packages/shared/src/index.ts"],
      "@ragemp-fivem-bridge/plugin-manager": ["packages/plugin-manager/src/index.ts"],
      "@ragemp-fivem-bridge/rage-rpc": ["packages/rage-rpc/src/index.ts"]
    },

    "strict": false,
    "noImplicitAny": true,
    "strictNullChecks": false
  }
}
